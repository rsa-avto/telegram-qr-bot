        payment = request.form.get("payment_method")

        if payment == "bonus":
            # Оплата бонусами сразу
            cur.execute("""
                UPDATE history
                SET Оплата='bonus', status='done', Рубли=?, points=0
                WHERE "№"=?
            """, (rub, order_id))

            # Уведомление оператору о бонусной оплате
            operator_telegram_id = STATION_OPERATORS.get(station_name)
