@app.route("/login")
def login():
    telegram_id = request.args.get("telegram_id")
    if not telegram_id:
        return "❌ Telegram ID не указан", 400

    telegram_id_int = int(telegram_id)

    # Проверка активных смен по базе (можно оставить)
    conn = get_db()
    cur = conn.cursor()
    cur.execute("SELECT 1 FROM shifts WHERE active = 1 LIMIT 1")
    active_shift = cur.fetchone()
    if active_shift:
        print("✅ Есть активные смены")
    else:
        print("❌ Нет активных смен")

    # Проверяем обычного пользователя
    cur.execute("SELECT id FROM users WHERE telegram_id = ?", (telegram_id_int,))
    user = cur.fetchone()

    # Проверка оператора через словарь STATION_OPERATORS
    operator_station = None
    for station_name, op_id in STATION_OPERATORS.items():
        if op_id == telegram_id_int:
            operator_station = station_name
            break

    if not user and not operator_station:
        conn.close()
        return "❌ Нет доступа", 403

    session["telegram_id"] = telegram_id_int
    session["is_admin"] = telegram_id_int in ADMIN_IDS

    if operator_station:
        # Оператор найден
        session["pending_operator"] = telegram_id_int
        session["station"] = operator_station  # сохраняем станцию оператора
        conn.close()
        return redirect("/operator/login")

    # Обычный пользователь
    session["role"] = "user"
    session["user_id"] = user["id"] if user else None

    conn.close()
    return redirect("/dashboard")


@app.route("/operator/login", methods=["GET", "POST"])
def operator_login():
    if "pending_operator" not in session:
        return redirect("/")

    telegram_id = session["pending_operator"]
    print(f"🔹 pending_operator: {telegram_id}")

    # --- Находим станцию по словарю STATION_OPERATORS ---
    station_name = None
    station_id = None
    for sid, name in STATION_NAMES.items():
        if STATION_OPERATORS.get(name) == telegram_id:
            station_name = name
            station_id = sid
            break

    if not station_id:
        print(f"❌ Для Telegram ID {telegram_id} нет станции")
        return "❌ На этой станции нет операторов в базе"

    print(f"✅ Станция найдена через словарь: {station_name} (id: {station_id})")

    conn = get_db()
    conn.row_factory = sqlite3.Row
    cur = conn.cursor()

    # --- Берем всех операторов на этой станции ---
    cur.execute("SELECT id, name, station FROM operators WHERE station = ?", (station_id,))
    operators = cur.fetchall()
    print(f"🔹 Найдено операторов: {len(operators)}")
    for op in operators:
        print(f"   - {op['name']} (id {op['id']})")

    if request.method == "POST":
        operator_id = request.form.get("operator_id")

        # Проверяем выбранного оператора
        selected_op = None
        for op in operators:
            if str(op["id"]) == str(operator_id):
                selected_op = op
                break

        if not selected_op:
            return "❌ Оператор не найден"

        # Логиним
        session.pop("pending_operator")
        session["telegram_id"] = telegram_id
        session["role"] = "operator"
        session["operator_id"] = selected_op["id"]
        session["station"] = selected_op["station"]

        return redirect("/operator")

    conn.close()
    return render_template("operator_login.html", operators=operators, station=station_name)




